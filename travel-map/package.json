{
  "name": "travel-map",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://map.pivi.dev",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "preview": "vite preview",
    "prepare": "cd .. & husky",
    "format": "prettier . --write",
    "predeploygh": "pnpm run build",
    "deploygh": "gh-pages -d dist --nojekyll",
    "update:packages": "ncu -u",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "depcheck": "depcheck --ignores=@babel/core,babel-plugin-react-compiler,depcheck,eslint-config-prettier,lint-staged --ignore-patterns=src/styles",
    "react:doctor": "react-doctor . --verbose",
    "doctor": "react-doctor"
  },
  "dependencies": {
    "apexcharts": "^6.0.0",
    "framer-motion": "^12.42.2",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "mobile-device-detect": "^0.4.3",
    "react": "^19.2.7",
    "react-apexcharts": "^2.1.1",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.9",
    "react-image-gallery": "^2.1.2",
    "react-photo-album": "^3.6.0",
    "react-router-dom": "^7.18.1",
    "react-simple-maps": "^3.0.0",
    "react-tooltip": "^6.0.8",
    "react-transition-group": "^4.4.5",
    "remeda": "^2.39.0",
    "swr": "^2.4.2"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-simple-maps": "^3.0.6",
    "@types/react-transition-group": "^4.4.12",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "depcheck": "^1.4.7",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "knip": "^6.27.0",
    "lint-staged": "^17.0.8",
    "npm-check-updates": "^22.2.9",
    "postcss": "^8.5.16",
    "prettier": "3.9.5",
    "react-doctor": "^0.8.1",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-qrcode": "^0.4.1",
    "vite-plugin-svgr": "^5.2.0"
  },
  "lint-staged": {
    "*.js": "pnpm run lint",
    "*.{js,css,md,html,json}": "pnpm run format"
  },
  "browserslist": {
    "production": [
      ">0.01%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      ">0.01%",
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
