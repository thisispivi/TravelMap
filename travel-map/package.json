{
  "name": "travel-map",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://map.pivi.dev",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "preview": "vite preview",
    "prepare": "cd .. & husky",
    "format": "prettier . --write",
    "predeploygh": "pnpm run build",
    "deploygh": "npx gh-pages -d dist",
    "update:packages": "ncu -u",
    "depcheck": "depcheck --ignores=babel-plugin-react-compiler,depcheck,eslint-config-prettier,d3,react-compiler-runtime,lint-staged --ignore-patterns=src/styles",
    "react:doctor": "npx -y react-doctor@latest . --verbose"
  },
  "dependencies": {
    "apexcharts": "^5.10.6",
    "d3": "^7.9.0",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "mobile-device-detect": "^0.4.3",
    "react": "^19.2.5",
    "react-apexcharts": "^2.1.0",
    "react-compiler-runtime": "^1.0.0",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.3",
    "react-image-gallery": "^2.1.2",
    "react-lazy-load-image-component": "^1.6.3",
    "react-photo-album": "^3.6.0",
    "react-router-dom": "^7.14.1",
    "react-simple-maps": "^3.0.0",
    "react-tooltip": "^5.30.1",
    "react-transition-group": "^4.4.5",
    "remeda": "^2.33.7"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-image-gallery": "^1.2.4",
    "@types/react-lazy-load-image-component": "^1.6.5",
    "@types/react-simple-maps": "^3.0.6",
    "@types/react-transition-group": "^4.4.12",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "depcheck": "^1.4.7",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "gh-pages": "^6.3.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.10",
    "prettier": "3.8.3",
    "sass": "^1.99.0",
    "terser": "^5.46.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-qrcode": "^0.4.1",
    "vite-plugin-svgr": "^5.2.0"
  },
  "lint-staged": {
    "*.js": "pnpm run lint",
    "*.{js,css,md,html,json}": "pnpm run format"
  },
  "browserslist": {
    "production": [
      ">0.01%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      ">0.01%",
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
